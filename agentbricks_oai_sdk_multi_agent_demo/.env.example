# Databricks configuration
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=
DATABRICKS_CONFIG_PROFILE=your-workspace

# Unity Catalog configuration
UC_CATALOG=your_catalog
UC_SCHEMA=your_schema
UC_VOLUME=ka_demo
TABLE_PREFIX=sec_fin_

# SQL Warehouse (for UC function execution and table verification)
SQL_WAREHOUSE_ID=your-warehouse-id

# Cluster (for running workspace notebooks)
CLUSTER_ID=your-cluster-id

# Genie Space ID (update after creating via notebook 07)
GENIE_SPACE_ID=

# Knowledge Assistant endpoint
KA_ENDPOINT=
KA_TILE_ID=

# MLflow configuration
MLFLOW_TRACKING_URI=databricks
MLFLOW_REGISTRY_URI=databricks-uc

# Server configuration
PORT=8000
