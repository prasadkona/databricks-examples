# =============================================================================
# Databricks Configuration
# =============================================================================
#
# Copy this file and fill in your values:
#   cp .env.template .env
#
# =============================================================================

# =============================================================================
# Workspace Connection
# =============================================================================

# Databricks workspace URL (required)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# =============================================================================
# Authentication (choose ONE method)
# =============================================================================

# Option 1: OAuth M2M - Service Principal (recommended for automation)
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# Option 2: Personal Access Token
# DATABRICKS_TOKEN=dapi...

# =============================================================================
# Unity Catalog
# =============================================================================

UC_CATALOG=main
UC_SCHEMA=default
UC_VOLUME=documents
UC_VOLUME_PATH=/Volumes/main/default/documents

# =============================================================================
# Compute Resources
# =============================================================================

# SQL Warehouse ID (for SQL queries and permissions)
SQL_WAREHOUSE_ID=

# Cluster ID (for notebook execution)
# CLUSTER_ID=

# =============================================================================
# Project-Specific Configuration
# =============================================================================

# Knowledge Assistant tile IDs (populated after creation)
KA_NAME_01=SEC_Financial_Analyst
KA_TILE_ID_01=

KA_NAME_02=SEC_Financial_Analyst_02
KA_TILE_ID_02=
